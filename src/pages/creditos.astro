---
import fs from "node:fs";
import "../styles/global.css";

type Credit = {
  src: string;
  title: string;
  creator: string;
  creator_url: string | null;
  license: string;
  license_version: string;
  license_url: string;
  foreign_landing_url: string;
  source: string;
};

const raw = JSON.parse(
  fs.readFileSync("public/photos/credits.json", "utf-8")
) as Record<string, Credit>;

const credits = Object.entries(raw).sort(([a], [b]) => a.localeCompare(b));
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Créditos fotográficos · IDCOM</title>
    <meta name="robots" content="noindex,follow" />

    <link rel="icon" type="image/png" href="/assets/idcom_mark.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800;900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#1A1A1A] text-white min-h-screen">
    <header class="border-b border-white/10 bg-[#1A1A1A]">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center">
          <img
            src="/assets/idcom_logo_transparent.png"
            alt="IDCOM"
            class="h-10 w-auto"
          />
        </a>
        <a
          href="/"
          class="text-xs font-semibold uppercase tracking-[0.18em] text-white/80 hover:text-[#F5A800] transition-colors"
        >
          ← Volver al sitio
        </a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-5 sm:px-8 py-16 sm:py-24">
      <div class="inline-flex items-center gap-3 mb-5">
        <span class="h-px w-10 bg-[#F5A800]"></span>
        <span class="text-xs font-semibold uppercase tracking-[0.32em] text-[#F5A800]">
          Atribución
        </span>
      </div>
      <h1 class="font-display font-extrabold text-5xl md:text-6xl tracking-tight">
        Créditos fotográficos
      </h1>
      <p class="mt-5 max-w-2xl text-white/70 text-lg leading-relaxed">
        Las imágenes en este sitio están bajo licencias{" "}
        <a
          href="https://creativecommons.org/about/cclicenses/"
          target="_blank"
          rel="noopener"
          class="text-[#F5A800] hover:underline"
        >
          Creative Commons
        </a>{" "}
        y dominio público, descargadas vía{" "}
        <a
          href="https://openverse.org"
          target="_blank"
          rel="noopener"
          class="text-[#F5A800] hover:underline"
        >
          Openverse
        </a>. A continuación, el detalle de autoría por cada imagen utilizada.
      </p>

      <ul class="mt-14 space-y-5">
        {
          credits.map(([id, c]) => (
            <li class="border-l-[3px] border-[#F5A800]/60 bg-white/[0.03] hover:bg-white/[0.06] transition-colors px-5 sm:px-6 py-5 grid sm:grid-cols-[120px_1fr] gap-5 items-start">
              <img
                src={c.src}
                alt={c.title}
                loading="lazy"
                decoding="async"
                class="w-full h-20 object-cover bg-[#1A1A1A]"
              />
              <div class="min-w-0">
                <div class="text-[10px] uppercase tracking-[0.24em] text-[#F5A800] font-semibold mb-1">
                  {id}
                </div>
                <div class="font-display font-extrabold text-lg text-white tracking-tight leading-snug">
                  {c.title}
                </div>
                <div class="mt-2 text-sm text-white/70 leading-relaxed">
                  por{" "}
                  {c.creator_url ? (
                    <a
                      href={c.creator_url}
                      target="_blank"
                      rel="noopener"
                      class="text-white hover:text-[#F5A800] underline underline-offset-2 decoration-[#F5A800]/40"
                    >
                      {c.creator}
                    </a>
                  ) : (
                    <span class="text-white">{c.creator}</span>
                  )}
                  {" · "}
                  <span class="uppercase">{c.source}</span>
                </div>
                <div class="mt-2 flex flex-wrap gap-3 text-xs text-white/60">
                  <a
                    href={c.license_url}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 px-2 py-1 border border-[#F5A800]/40 text-[#F5A800] font-bold uppercase tracking-wider hover:bg-[#F5A800] hover:text-[#1A1A1A] transition-colors"
                  >
                    {c.license}
                    {c.license_version ? ` ${c.license_version}` : ""}
                  </a>
                  <a
                    href={c.foreign_landing_url}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center hover:text-[#F5A800] transition-colors"
                  >
                    Ver original ↗
                  </a>
                </div>
              </div>
            </li>
          ))
        }
      </ul>

      <p class="mt-14 text-sm text-white/50 leading-relaxed max-w-2xl">
        IDCOM utiliza estas imágenes con fines ilustrativos. Si eres titular de
        alguno de los derechos y deseas que retiremos o ajustemos la
        atribución, escríbenos a{" "}
        <a
          href="mailto:ventas@idcom.com.ec"
          class="text-[#F5A800] hover:underline"
        >
          ventas@idcom.com.ec
        </a>.
      </p>
    </main>

    <footer class="border-t border-white/10 mt-12">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-6 text-center text-xs text-white/40">
        © {year} IDCOM — Ingeniería en Diseño y Construcciones Metalmecánicas.
      </div>
    </footer>
  </body>
</html>
